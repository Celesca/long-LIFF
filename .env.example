# Backend API URL (optional, defaults to http://localhost:8000)
VITE_API_URL=http://localhost:8000

# Frontend-only mode is the default. Set true to reconnect FastAPI.
VITE_USE_REAL_API=false

# LIFF ID (get from LINE Developers Console)
VITE_LIFF_ID=

# Docker Compose settings for the backend stack
# Replace these passwords before deploying to a VPS.
POSTGRES_DB=long_liff
POSTGRES_USER=long_liff
POSTGRES_PASSWORD=change-this-database-password
MINIO_ACCESS_KEY=longliff
MINIO_SECRET_KEY=change-this-minio-secret

# Exact browser origins allowed to call the API (comma-separated, no path).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Image-cache worker schedule and limits
IMAGE_CACHE_INTERVAL_SECONDS=21600
IMAGE_CACHE_RETRY_HOURS=12
IMAGE_CACHE_MAX_PER_PLACE=3
